rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Functions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) && 
             data.keys().size() == 2 && 
             data.email is string && data.email.size() <= 100 &&
             data.createdAt == request.time;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      // Disallow updating profiles for now
      allow update: if false;
      allow delete: if false;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'email', 'amount', 'currency', 'items', 'status', 'reference', 'createdAt']) &&
             data.keys().size() == 8 &&
             data.userId == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             data.amount is number &&
             data.currency is string && data.currency.size() <= 10 &&
             data.items is list && data.items.size() <= 100 &&
             data.status == 'completed' &&
             data.reference is string && data.reference.size() <= 100 &&
             data.createdAt == request.time;
    }

    match /orders/{orderId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidOrder(incoming()) && exists(/databases/$(database)/documents/users/$(incoming().userId));
      allow update: if false;
      allow delete: if false;
    }
  }
}
